modifyChild()
{
	// from Manisha Munasinghe
	// check mtdNA from female parent not male parent
	if (!childGenome1.containsMarkerMutation(m2, 0)) // LENGTHY
		return F;
	if (childGenome2.containsMarkerMutation(m2, 0))
		return F;
	
	// remove mutations from "male" mtdna
	childGenome2.removeMutations(childGenome2.mutationsOfType(m1));
	return T;

}


1 early() {
	catn("setting up subpopulations and map");
	// setting up subpop1, the map, constraining to the area of the map
	sim.addSubpop("p1", sum(K), sexRatio);
	
	// set up the other two subpopulations in case we need them later
	sim.addSubpop("p2",0,sexRatio);
	sim.addSubpop("p3",0,sexRatio);
	
	mapLines = (readFile(nicheFile));
	mapLines = sapply(mapLines, "strsplit(applyValue, ' ');");
	mapValues = asFloat(mapLines);
	mapValues = t(matrix(mapValues,nrow=nicheX));
	//cat(mapValues);
	sim.subpopulations.defineSpatialMap("map1", "xy", mapValues, interpolate=F,
		valueRange=c(-1.0, 3.0),colors=spatialcolors);
	//	for (ind in sim.subpopulations[0].individuals) {
	//		ind.setSpatialPosition(p1.pointUniform());		
	//	}
	
	// setting up the spatial distribution 
	p1.individuals.setSpatialPosition(p1.pointUniform(sum(K)));
	locs=(sim.subpopulations[0].individuals.spatialPosition);
	number_outofbounds=(length(which((sim.subpopulations[0].spatialMapValue("map1",locs))==-1)));
	
	while(number_outofbounds >0){
		//cat(number_outofbounds,sep=";");
		these_inds=(sim.subpopulations[0].individuals[which((sim.subpopulations[0].spatialMapValue("map1",locs))==-1)]);
		these_inds.setSpatialPosition(p1.pointUniform(number_outofbounds));
		locs=(sim.subpopulations[0].individuals.spatialPosition); // LENGTHY
		number_outofbounds=(length(which((sim.subpopulations[0].spatialMapValue("map1",locs))==-1)));
	}
}
1 early() {
	catn("setting up haploid mtDNA");
	// set up the haploid mitochondria 
	inds = sim.subpopulations.individuals;
	mito = inds.genomes[seqAlong(inds) * 2]; // LENGTHY
	
	// cannot do this with treeseq recording if age distribution is set already
	mito.addNewDrawnMutation(m2, 0);
	
	//set up mitochondrial mutations for selection
	//mito.addNewDrawnMutation(m3, 8000);
	
	// setting up the age distribution
	p1.individuals.age = rdunif(sum(K), min=0, max=7);


}

1 early() {
	catn("rescheduling blocks");
	// all of these already include burnin
	sim.rescheduleScriptBlock(s3, start=barrier1gen,end=barrier1gen);
	sim.rescheduleScriptBlock(s4, start=barrier2gen,end=barrier2gen);
	sim.rescheduleScriptBlock(s5, start=outputGen,end=outputGen);

}

early() {
	catn("marking males for mating");
	// randomly mark males for mating success per generation
	for (i in 0:2) {
		males = sim.subpopulations[i].subsetIndividuals(sex="M");
		probability=(1/females_per_male);
		males.tag=rbinom(length(males),1,probability); // LENGTHY
	}
}

early() {
	catn("carrying out life table, competition, survival");
	// life table based individual mortality 
	// for carrying capacity, should do based on where the inds are 
	
	//pos = individual.spatialPosition + rnorm(2, dispMale, dispDevMale);
	//this_location = subpop.spatialMapValue("map1",pos);	
	
	for (i in 0:2) {
		inds = sim.subpopulations[i].individuals;
		
		if(length(inds) > 0) {
			
			// look at probability of death by age
			ages = inds.age;
			mortality = L[ages];
			survival = 1 - mortality;
			
			// evaluate competition
			if(comp==1){
				
				// problem with point periodic again -- out of bounds for a periodic spatial dimension 
				i1.evaluate();
				competition = i1.totalOfNeighborStrengths(inds); // LENGTHY
				competition = (competition + 1) / (PI * S1^2);
				
				
				// need to figure out both competition and survival		
				inds.fitnessScaling = survival * (K[i] / competition);
			} else {
				inds.fitnessScaling = survival;
			}
			
			// density-dependence, factoring in individual mortality
			sim.subpopulations[i].fitnessScaling = K[i] / (sim.subpopulations[i].individualCount * mean(survival));
		}
	}

}


late() {
	
	//inds = p1.individuals; 
	//catn(sim.generation + ": " + size(inds) + " (" + max(inds.age) + ")"); 
	
	// print our age distribution after mortality 
	//catn(sim.generation + ": " + paste(sort(p1.individuals.age)));
	
	// move around a bit 
	catn("moving individuals");
	for (i in 0:2) {
		inds = sim.subpopulations[i].individuals;
		if(length(inds)>0){
			
			for (ind in inds) {
				newPos = ind.spatialPosition + runif(2, -0.01, 0.01); // LENGTHY
			}
			// then look for mates 
			
			if(ibd==1) {
				i2.evaluate();
			}
		
		}
	}
	catn("finishing gen:"+sim.generation);
}

